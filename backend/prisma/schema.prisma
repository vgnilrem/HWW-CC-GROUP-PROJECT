generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Users now use username as the primary ID
model User {
  username  String      @id
  email     String      @unique
  password  String
  playlists Playlist[]
  ratings   Rating[]
  watchlist Watchlist[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

/// Unified model for both Movies and TV Shows
model Media {
  tmdbId        Int             @id
  title         String
  type          MediaType       @default(MOVIE)
  genres        Genre[]
  description   String?
  posterUrl     String?
  producer      String?
  releaseYear   Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  episodes      Episode[]
  playlistMedia PlaylistMedia[]
  ratings       Rating[]
  watchlist     Watchlist[]
}

/// Episodes reference a Media item by TMDB ID (only used for TV series)
model Episode {
  mediaTmdbId   Int
  seasonNumber  Int
  episodeNumber Int
  name          String
  airDate       DateTime?
  createdAt     DateTime  @default(now())

  media Media @relation(fields: [mediaTmdbId], references: [tmdbId], onDelete: Cascade)

  @@id([mediaTmdbId, seasonNumber, episodeNumber])
}

