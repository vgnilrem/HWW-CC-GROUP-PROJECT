/// Each watchlist entry links one user ↔ one media item
model Watchlist {
  userUsername String
  mediaTmdbId  Int
  status       WatchStatus @default(PLANNED)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt

  user  User  @relation(fields: [userUsername], references: [username], onDelete: Cascade)
  media Media @relation(fields: [mediaTmdbId], references: [tmdbId], onDelete: Cascade)

  @@id([userUsername, mediaTmdbId])
}

/// Playlist belongs to a single user
model Playlist {
  id            Int             @id @default(autoincrement())
  ownerUsername String
  name          String
  isPublic      Boolean         @default(true)
  isFavorite    Boolean         @default(false)
  playlistMedia PlaylistMedia[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt

  owner User @relation(fields: [ownerUsername], references: [username], onDelete: Cascade)

  @@unique([name, ownerUsername]) // keep this unique to prevent duplicates
}

/// PlaylistMedia connects playlists with TV series and Movies
model PlaylistMedia {
  playlistName  String
  ownerUsername String
  mediaTmdbId   Int
  playlist Playlist @relation(fields: [playlistName, ownerUsername], references: [name, ownerUsername], onDelete: Cascade)
  media    Media    @relation(fields: [mediaTmdbId], references: [tmdbId], onDelete: Cascade)
  @@id([playlistName, ownerUsername, mediaTmdbId])
}

/// Enums
enum MediaType {
  MOVIE
  TV
}

enum WatchStatus {
  WATCHING
  COMPLETED
  PLANNED
  DROPPED
  REMOVED
}

enum Genre {
  ACTION
  COMEDY
  DRAMA
  FANTASY
  HORROR
  ROMANCE
  SCIFI
  THRILLER
  ANIMATION
}
